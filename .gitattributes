# Auto detect text files and perform LF normalization on checkout
* text=auto eol=lf

# Source files
core/src/*.cpp text eol=lf
*.hpp text eol=lf
*.h text eol=lf
*.c text eol=lf
*.qml text eol=lf
*.js text eol=lf
*.json text eol=lf
*.frag text eol=lf
*.comp text eol=lf
*.vert text eol=lf
*.cmake text eol=lf
CMakeLists.txt text eol=lf
*.py text eol=lf
*.sh text eol=lf
*.fish text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.md text eol=lf
*.ts text eol=lf

# Windows-specific files must keep CRLF
*.rc text eol=crlf
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# Binary files (do not modify line endings)
*.ico binary
*.png binary
*.jpg binary
*.jpeg binary
*.webp binary
*.svg text eol=lf
*.ttf binary
*.wav binary
*.mp3 binary
*.mp4 binary
*.qsb binary
*.zip binary
*.7z binary
*.qm binary
*.gz binary
*.tar binary
*.exe binary
*.dll binary
*.lib binary
*.a binary
*.so binary
*.dylib binary
