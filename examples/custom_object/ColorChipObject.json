{
    "id": "color_chip",
    "name": "Color Chip",
    "qml": "ColorChipObject.qml",
    "color": "#f472b6",
    "version": "1.0.0",
    "kind": "object",
    "categories": ["Custom"],
    "params": {
        "sizeW": 200,
        "sizeH": 200,
        "color": "#f472b6",
        "cornerRadius": 8,
        "opacity": 1.0
    },
    "ui": {
        "controls": [
            {
                "type": "float",
                "param": "sizeW",
                "label": "Width",
                "min": 1,
                "max": 4000
            },
            {
                "type": "float",
                "param": "sizeH",
                "label": "Height",
                "min": 1,
                "max": 4000
            },
            {
                "type": "color",
                "param": "color",
                "label": "Color"
            },
            {
                "type": "float",
                "param": "cornerRadius",
                "label": "Corner Radius",
                "min": 0,
                "max": 200
            },
            {
                "type": "slider",
                "param": "opacity",
                "label": "Opacity",
                "min": 0,
                "max": 1,
                "step": 0.01
            }
        ]
    }
}
