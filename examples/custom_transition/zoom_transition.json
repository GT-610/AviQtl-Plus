{
    "id": "zoom_transition",
    "name": "Zoom Transition",
    "qml": "ZoomTransition.qml",
    "params": {
        "duration": 30,
        "easing": "ease_in_out",
        "reverse": false
    },
    "ui": {
        "group": "transition",
        "controls": [
            {
                "type": "spinner",
                "param": "duration",
                "label": "Duration (frames)",
                "min": 1,
                "max": 300,
                "step": 1
            },
            {
                "type": "enum",
                "param": "easing",
                "label": "Easing",
                "options": ["linear", "ease_in", "ease_out", "ease_in_out"]
            },
            {
                "type": "bool",
                "param": "reverse",
                "label": "Reverse"
            }
        ]
    },
    "version": "1.0.0",
    "kind": "transition",
    "color": "#10b981",
    "categories": ["Basic", "Zoom"]
}
