{
    "id": "zoom",
    "name": "ズーム",
    "qml": "Zoom.qml",
    "params": {
        "duration": 30,
        "easing": "ease_in_out",
        "reverse": false,
        "zoomScale": 1.5
    },
    "ui": {
        "group": "transition",
        "controls": [
            {
                "type": "spinner",
                "param": "duration",
                "label": "持続フレーム",
                "min": 1,
                "max": 300,
                "step": 1
            },
            {
                "type": "enum",
                "param": "easing",
                "label": "イージング",
                "options": ["linear", "ease_in", "ease_out", "ease_in_out"]
            },
            {
                "type": "bool",
                "param": "reverse",
                "label": "反転"
            },
            {
                "type": "slider",
                "param": "zoomScale",
                "label": "ズーム倍率",
                "min": 1.0,
                "max": 5.0,
                "step": 0.1
            }
        ]
    },
    "version": "1.0.0",
    "kind": "transition",
    "color": "#9C27B0",
    "categories": [
        "ズーム",
        "基本"
    ]
}
