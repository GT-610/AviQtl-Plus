{
    "id": "wipe_circle",
    "name": "ワイプ（円）",
    "qml": "WipeCircle.qml",
    "params": {
        "duration": 30,
        "easing": "linear",
        "reverse": false,
        "centerX": 0.5,
        "centerY": 0.5
    },
    "ui": {
        "group": "transition",
        "controls": [
            {
                "type": "spinner",
                "param": "duration",
                "label": "持続フレーム",
                "min": 1,
                "max": 300,
                "step": 1
            },
            {
                "type": "enum",
                "param": "easing",
                "label": "イージング",
                "options": ["linear", "ease_in", "ease_out", "ease_in_out"]
            },
            {
                "type": "bool",
                "param": "reverse",
                "label": "反転"
            },
            {
                "type": "slider",
                "param": "centerX",
                "label": "中心X",
                "min": 0,
                "max": 1,
                "step": 0.01
            },
            {
                "type": "slider",
                "param": "centerY",
                "label": "中心Y",
                "min": 0,
                "max": 1,
                "step": 0.01
            }
        ]
    },
    "version": "1.0.0",
    "kind": "transition",
    "color": "#9C27B0",
    "categories": [
        "ワイプ",
        "円形"
    ]
}